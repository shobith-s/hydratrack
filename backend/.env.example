# ─────────────────────────────────────────────────────────────────────────────
# HydroTrack Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# When deploying to HuggingFace Spaces: add these as Repository Secrets
#   → Space Settings → Variables and secrets → New secret
#
# For local development: copy to backend/.env (already in .gitignore)
#
# HOW TO GET THESE VALUES:
#   1. Supabase → Project Settings → API
#      SUPABASE_URL     = Project URL
#      SUPABASE_SERVICE_KEY = service_role key (NOT the anon key)
#      SUPABASE_JWT_SECRET  = JWT Secret (under "JWT Settings")
#   2. Run: python scripts/generate-vapid.py
#      VAPID_PUBLIC_KEY  = printed public key
#      VAPID_PRIVATE_KEY = printed private key
#   3. ALLOWED_ORIGINS = your Vercel app URL (comma-separated for multiple)
# ─────────────────────────────────────────────────────────────────────────────

SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_CLAIMS_EMAIL=your@email.com

# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
